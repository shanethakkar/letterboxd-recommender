# Constellation — environment template. Copy to `.env` and fill in.
# `.env` is gitignored; this file (no secrets) is committed.

# TMDB v3 API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Redis connection URL. Leave blank for in-process fakeredis (local dev).
# Production: redis://<host>:<port>/<db>
REDIS_URL=
